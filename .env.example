# ── Infrastructure ──────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://trading:trading_dev@localhost:5432/trading
DB_PASSWORD=trading_dev

# ── IBKR ────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=10
IBKR_EXECUTION_CLIENT_ID=20

# ── Kraken ──────────────────────────────────────────
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_SYMBOLS=BTC/USD,ETH/USD
KRAKEN_L3_ENABLED=true

# ── Catalyst APIs ───────────────────────────────────
# Polygon.io (optional — for equity news if added later)
POLYGON_API_KEY=

# CryptoQuant (optional — on-chain data)
CRYPTOQUANT_API_KEY=

# ── ML / Agents ─────────────────────────────────────
# Path to ONNX model files on local disk
ORDER_FLOW_MODEL_PATH=./models/order-flow-lstm.onnx
CATALYST_LLM_MODEL_PATH=./models/catalyst-7b-q4

# ── General ─────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
