{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true
  },
  "references": [
    { "path": "packages/types" },
    { "path": "packages/ingestion-ibkr" },
    { "path": "packages/ingestion-kraken" },
    { "path": "packages/features" },
    { "path": "packages/storage" },
    { "path": "packages/catalysts" },
    { "path": "packages/agents" },
    { "path": "packages/orchestrator" },
    { "path": "packages/execution" }
  ]
}
